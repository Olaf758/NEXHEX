<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="using:NEXHEX"
		xmlns:consts="using:Nexomon2Model"
        mc:Ignorable="d"
		Icon="nexotrap-golden.ico"
        x:Class="NEXHEX.MainWindow"
		x:DataType="vm:ViewModel"
		x:Name="NEXHEX"
        Title="NEXHEX"
		Width="800">
	<Window.DataTemplates>
		<DataTemplate DataType="vm:Nex2ViewModel">
			<vm:Nex2View/>
		</DataTemplate>
		<DataTemplate DataType="vm:Nex1ViewModel">
			<vm:Nex1View/>
		</DataTemplate>
	</Window.DataTemplates>
	
	<StackPanel Margin="20" Orientation ="Horizontal">
		
		<StackPanel HorizontalAlignment="Center">
			<Button
				Content="import"
				HorizontalContentAlignment="Center"
				Command="{Binding SaveFileManagerUnit.SelectSaveFileCommand}"
				Width="100" FontSize="18"/>
			<Button
				Content="save"
				HorizontalContentAlignment="Center"
				Command="{Binding SaveFileManagerUnit.SaveToDirCommand}"
				Width="100" FontSize="18"/>
			<HyperlinkButton
               NavigateUri="https://ko-fi.com/snowman758/donate"
               Content="☕ Donate"
	           MaxWidth="100" FontSize="15"
               HorizontalAlignment="Left"/>
		</StackPanel>

		<ContentControl Content="{Binding CurrentViewModel}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="20,0,0,0"/>
	</StackPanel>
</Window>
